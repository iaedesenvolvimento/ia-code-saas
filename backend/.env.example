# Configurações do Servidor
PORT=3000

# JWT Secret (mude para algo seguro em produção)
JWT_SECRET=seu_jwt_secret_super_seguro_aqui

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/dbname

# OpenRouter API Key
OPENROUTER_KEY=sk-or-v1-sua-chave-aqui

# Stripe Keys (use sk_test_ para desenvolvimento, sk_live_ para produção)
STRIPE_KEY=sk_test_sua_chave_stripe_aqui
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui

# URL do Frontend (será configurada automaticamente no Render)
FRONTEND_URL=http://localhost:3000